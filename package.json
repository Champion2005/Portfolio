{
  "name": "portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:resume": "node scripts/build-resume.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean:gh-pages-cache": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('node_modules/.cache/gh-pages', { recursive: true, force: true });\"",
    "deploy": "npm run build && npm run clean:gh-pages-cache && gh-pages -d dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.8",
    "@tsparticles/react": "3.0.0",
    "@tsparticles/slim": "3.9.1",
    "motion": "^12.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "gh-pages": "^6.3.0",
    "globals": "^15.12.0",
    "node-latex-compiler": "^1.0.5",
    "tailwindcss": "^4.0.0-beta.8",
    "vite": "^6.0.1"
  },
  "save-exact": "true"
}
